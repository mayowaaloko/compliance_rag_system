# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Environment Variable Template
# ─────────────────────────────────────────────────────────────────────────────
#
# HOW TO USE:
#   1. Copy this file to .env:   cp .env.example .env
#   2. Fill in every value below
#   3. NEVER commit .env to git  (it is in .gitignore)
#
# This file is safe to commit — it contains no real secrets.
# ─────────────────────────────────────────────────────────────────────────────


# ─────────────────────────────────────────────────────────────────────────────
# API KEYS (REQUIRED)
# ─────────────────────────────────────────────────────────────────────────────

# OpenAI — used for embeddings (text-embedding-3-small) and compliance report generation (gpt-4o-mini)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Groq — used for fast query rewriting (multi-query expansion)
# Get from: https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# LangSmith — optional observability and tracing
# Leave blank to disable. Get from: https://smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=compliance-rag-2026


# ─────────────────────────────────────────────────────────────────────────────
# JWT AUTHENTICATION (REQUIRED)
# ─────────────────────────────────────────────────────────────────────────────

# Secret key for signing JWT tokens.
# Generate a secure random key with: openssl rand -hex 32
# CRITICAL: use a different key for every deployment. Never share this.
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production

# JWT algorithm (HS256 is the standard — do not change unless you know why)
JWT_ALGORITHM=HS256

# How long tokens stay valid (in minutes). 480 = 8 hours.
JWT_EXPIRE_MINUTES=480


# ─────────────────────────────────────────────────────────────────────────────
# LLM MODELS
# ─────────────────────────────────────────────────────────────────────────────

# Groq model for multi-query expansion (fast, cheap)
# Options: llama-3.3-70b-versatile, mixtral-8x7b-32768, gemma2-9b-it
# The notebook uses: openai/gpt-oss-120b (via Groq OpenAI-compatible endpoint)
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI model for the main compliance report (structured output)
# Options: gpt-4o-mini (fast/cheap), gpt-4o (best quality)
OPENAI_MODEL=gpt-4o-mini

# Temperature for the compliance LLM (0.0 = deterministic, required for compliance)
TEMPERATURE=0.0


# ─────────────────────────────────────────────────────────────────────────────
# EMBEDDING MODEL
# ─────────────────────────────────────────────────────────────────────────────

EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small


# ─────────────────────────────────────────────────────────────────────────────
# QDRANT VECTOR DATABASE (REQUIRED)
# ─────────────────────────────────────────────────────────────────────────────

# For local Docker (via docker-compose.yml):
#   QDRANT_URL=http://localhost:6333
#   QDRANT_API_KEY=          (leave blank — local Qdrant has no auth by default)
#
# For Qdrant Cloud:
#   QDRANT_URL=https://your-cluster-id.us-east4-0.gcp.cloud.qdrant.io
#   QDRANT_API_KEY=your-qdrant-cloud-api-key

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=compliance_docs


# ─────────────────────────────────────────────────────────────────────────────
# SUPABASE (REQUIRED)
# ─────────────────────────────────────────────────────────────────────────────

# Get from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Full PostgreSQL connection string for direct DB access
# Get from: Supabase Dashboard → Project Settings → Database → Connection string (URI)
# Format: postgresql://postgres:[password]@db.[project-id].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:your-password@db.your-project-id.supabase.co:5432/postgres


# ─────────────────────────────────────────────────────────────────────────────
# DOCUMENT PATHS
# ─────────────────────────────────────────────────────────────────────────────

# Folder containing compliance PDFs (relative to the project root)
COMPLIANCE_DOCS_DIR=./documents/

# Folder for the on-disk embedding cache (saves OpenAI API cost on re-ingestion)
EMBEDDING_CACHE_DIR=./.embedding_cache


# ─────────────────────────────────────────────────────────────────────────────
# RAG HYPERPARAMETERS
# ─────────────────────────────────────────────────────────────────────────────

# Chunk size in characters (not tokens or words)
CHUNK_SIZE=600

# Overlap between consecutive chunks in characters
# Must be smaller than CHUNK_SIZE
CHUNK_OVERLAP=80

# How many candidates to retrieve from Qdrant before reranking
TOP_K_RETRIEVAL=20

# How many top chunks to keep after cross-encoder reranking
TOP_K_RERANK=5

# Maximum tokens to send to the LLM as context
MAX_CONTEXT_TOKENS=7000

# RAGAS faithfulness threshold (alert if below this during evaluation)
MIN_FAITHFULNESS=0.80


# ─────────────────────────────────────────────────────────────────────────────
# RATE LIMITING
# ─────────────────────────────────────────────────────────────────────────────

# Maximum /query requests per user per minute
# Prevents LLM cost spikes from runaway clients
RATE_LIMIT_PER_MINUTE=10


# ─────────────────────────────────────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────────────────────────────────────

# Comma-separated list of allowed frontend origins.
# Use * to allow all origins (development only).
# For production: CORS_ORIGINS=https://your-frontend.com,https://app.yourcompany.com
CORS_ORIGINS=*
